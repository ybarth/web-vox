{
  "manifest_version": 3,
  "name": "Web Vox",
  "version": "0.1.0",
  "description": "OS-level TTS with audio capture for web pages",
  "permissions": ["nativeMessaging"],
  "background": {
    "scripts": ["dist/background/service-worker.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/bridge.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "web-vox@example.com"
    }
  }
}
